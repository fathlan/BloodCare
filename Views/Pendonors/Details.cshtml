@model BloodCare.Models.Pendonor

@{
    ViewData["Title"] = "Detail Pendonor";
}

<div class="bloodcare-detail-page">
    <div class="detail-hero">
        <div>
            <span class="page-label">BloodCare Profile</span>
            <h1>Detail Pendonor</h1>
            <p>Informasi lengkap pendonor darah yang tersimpan pada sistem BloodCare.</p>
        </div>

        <a asp-action="Index" class="btn-back">Kembali</a>
    </div>

    <div class="detail-card">
        <div class="profile-section">
            <div class="profile-avatar">
                @Model.GolonganDarah
            </div>

            <div>
                <h2>@Model.Nama</h2>
                <p>@Model.JenisKelamin • @Model.Umur tahun</p>
                <span class="blood-badge">@Model.GolonganDarah @Model.Rhesus</span>
            </div>
        </div>

        <div class="info-grid">
            <div class="info-item">
                <span>Nama Lengkap</span>
                <strong>@Model.Nama</strong>
            </div>

            <div class="info-item">
                <span>Umur</span>
                <strong>@Model.Umur tahun</strong>
            </div>

            <div class="info-item">
                <span>Jenis Kelamin</span>
                <strong>@Model.JenisKelamin</strong>
            </div>

            <div class="info-item">
                <span>Golongan Darah</span>
                <strong>@Model.GolonganDarah</strong>
            </div>

            <div class="info-item">
                <span>Rhesus</span>
                <strong>@Model.Rhesus</strong>
            </div>

            <div class="info-item">
                <span>Nomor HP</span>
                <strong>@Model.NoHP</strong>
            </div>

            <div class="info-item full">
                <span>Alamat</span>
                <strong>@Model.Alamat</strong>
            </div>

            <div class="info-item">
                <span>Tanggal Donor Terakhir</span>
                <strong>@Model.TanggalDonorTerakhir.ToString("dd MMMM yyyy")</strong>
            </div>
        </div>

        <div class="detail-actions">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-edit">Edit Data</a>
            <a asp-action="Index" class="btn-cancel">Kembali ke Data Pendonor</a>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #fff5f5 0%, #ffffff 45%, #f8fafc 100%);
        font-family: 'Segoe UI', sans-serif;
    }

    .bloodcare-detail-page {
        padding: 28px 0 60px;
    }

    .detail-hero {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
        padding: 30px;
        border-radius: 30px;
        background: radial-gradient(circle at top right, rgba(255,255,255,0.28), transparent 28%), linear-gradient(135deg, #991b1b, #ef4444);
        color: white;
        box-shadow: 0 22px 50px rgba(185, 28, 28, 0.25);
    }

    .page-label {
        display: inline-block;
        margin-bottom: 10px;
        padding: 7px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.18);
        font-size: 13px;
        letter-spacing: 0.5px;
    }

    .detail-hero h1 {
        margin: 0;
        font-size: 36px;
        font-weight: 850;
    }

    .detail-hero p {
        margin: 8px 0 0;
        opacity: 0.92;
    }

    .btn-back {
        text-decoration: none;
        background: white;
        color: #b91c1c;
        padding: 13px 19px;
        border-radius: 16px;
        font-weight: 800;
        box-shadow: 0 12px 25px rgba(0,0,0,0.14);
        transition: 0.2s;
        white-space: nowrap;
    }

        .btn-back:hover {
            transform: translateY(-2px);
            color: #991b1b;
        }

    .detail-card {
        border-radius: 30px;
        background: rgba(255,255,255,0.96);
        border: 1px solid #fee2e2;
        box-shadow: 0 20px 55px rgba(15, 23, 42, 0.09);
        padding: 30px;
    }

    .profile-section {
        display: flex;
        align-items: center;
        gap: 20px;
        padding-bottom: 26px;
        margin-bottom: 26px;
        border-bottom: 1px solid #fee2e2;
    }

    .profile-avatar {
        width: 86px;
        height: 86px;
        border-radius: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #dc2626, #fb7185);
        color: white;
        font-size: 30px;
        font-weight: 900;
        box-shadow: 0 16px 30px rgba(220, 38, 38, 0.28);
    }

    .profile-section h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 850;
        color: #111827;
    }

    .profile-section p {
        margin: 6px 0 10px;
        color: #64748b;
        font-weight: 600;
    }

    .blood-badge {
        display: inline-flex;
        padding: 7px 14px;
        border-radius: 999px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 850;
        font-size: 14px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    .info-item {
        padding: 20px;
        border-radius: 22px;
        background: #fffafa;
        border: 1px solid #fee2e2;
    }

        .info-item.full {
            grid-column: span 3;
        }

        .info-item span {
            display: block;
            margin-bottom: 8px;
            color: #64748b;
            font-size: 14px;
            font-weight: 700;
        }

        .info-item strong {
            color: #111827;
            font-size: 17px;
            font-weight: 850;
        }

    .detail-actions {
        display: flex;
        gap: 12px;
        margin-top: 30px;
        padding-top: 22px;
        border-top: 1px solid #f1f5f9;
    }

    .btn-edit {
        text-decoration: none;
        padding: 13px 22px;
        border-radius: 16px;
        background: linear-gradient(135deg, #dc2626, #fb7185);
        color: white;
        font-weight: 850;
        box-shadow: 0 12px 24px rgba(220, 38, 38, 0.25);
        transition: 0.2s;
    }

        .btn-edit:hover {
            transform: translateY(-2px);
            color: white;
        }

    .btn-cancel {
        text-decoration: none;
        padding: 13px 22px;
        border-radius: 16px;
        background: #f1f5f9;
        color: #334155;
        font-weight: 800;
        transition: 0.2s;
    }

        .btn-cancel:hover {
            background: #e2e8f0;
            color: #111827;
        }

    @@media (max-width: 992px) {
        .info-grid {
            grid-template-columns: 1fr 1fr;
        }

        .info-item.full {
            grid-column: span 2;
        }
    }

    @@media (max-width: 768px) {
        .detail-hero {
            flex-direction: column;
            align-items: flex-start;
        }

        .profile-section {
            flex-direction: column;
            align-items: flex-start;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .info-item.full {
            grid-column: span 1;
        }

        .detail-hero h1 {
            font-size: 28px;
        }

        .detail-actions {
            flex-direction: column;
        }
    }
</style>