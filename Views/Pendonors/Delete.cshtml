@model BloodCare.Models.Pendonor

@{
    ViewData["Title"] = "Hapus Pendonor";
}

<div class="delete-container">
    <div class="delete-card">

        <!-- HEADER -->
        <div class="delete-header">
            <div class="icon">!</div>
            <h2>Hapus Data Pendonor</h2>
            <p>Apakah kamu yakin ingin menghapus data ini? Tindakan ini tidak dapat dibatalkan.</p>
        </div>

        <!-- DATA -->
        <div class="delete-info">
            <div class="info-item">
                <span>Nama</span>
                <strong>@Model.Nama</strong>
            </div>

            <div class="info-item">
                <span>Golongan Darah</span>
                <strong>@Model.GolonganDarah @Model.Rhesus</strong>
            </div>

            <div class="info-item">
                <span>Nomor HP</span>
                <strong>@Model.NoHP</strong>
            </div>
        </div>

        <!-- ACTION -->
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="delete-actions">
                <button type="submit" class="btn-delete">Ya, Hapus</button>
                <a asp-action="Index" class="btn-cancel">Batal</a>
            </div>
        </form>

    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #fff1f2, #ffffff);
        font-family: 'Segoe UI', sans-serif;
    }

    .delete-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 60px 20px;
    }

    .delete-card {
        width: 100%;
        max-width: 500px;
        background: white;
        border-radius: 30px;
        padding: 30px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
        border: 1px solid #fee2e2;
        text-align: center;
    }

    .delete-header {
        margin-bottom: 25px;
    }

        .delete-header .icon {
            width: 60px;
            height: 60px;
            border-radius: 20px;
            background: linear-gradient(135deg, #dc2626, #fb7185);
            color: white;
            font-size: 28px;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
        }

        .delete-header h2 {
            margin: 0;
            font-weight: 800;
            color: #111827;
        }

        .delete-header p {
            margin-top: 10px;
            color: #64748b;
            font-size: 14px;
        }

    .delete-info {
        display: grid;
        gap: 12px;
        margin-bottom: 25px;
        text-align: left;
    }

    .info-item {
        padding: 12px 15px;
        border-radius: 12px;
        background: #fffafa;
        border: 1px solid #fee2e2;
    }

        .info-item span {
            font-size: 12px;
            color: #64748b;
        }

        .info-item strong {
            display: block;
            font-weight: 700;
            color: #111827;
        }

    .delete-actions {
        display: flex;
        gap: 10px;
    }

    .btn-delete {
        flex: 1;
        padding: 12px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        color: white;
        font-weight: 800;
        cursor: pointer;
    }

        .btn-delete:hover {
            background: linear-gradient(135deg, #b91c1c, #991b1b);
        }

    .btn-cancel {
        flex: 1;
        text-align: center;
        padding: 12px;
        border-radius: 12px;
        background: #e2e8f0;
        color: #111827;
        text-decoration: none;
        font-weight: 700;
    }
</style>