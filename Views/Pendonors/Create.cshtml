@model BloodCare.Models.Pendonor

@{
    ViewData["Title"] = "Tambah Pendonor";
}

<div style="max-width:700px;margin:0 auto">
    <div class="bc-form-card">
        <div class="bc-form-header">
            <h5>👤 Tambah Data Pendonor</h5>
            <div style="font-size:0.82rem;opacity:0.85;margin-top:3px">Isi data lengkap pendonor darah baru</div>
        </div>
        <div class="bc-form-body">
            <form asp-action="Create">
                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label asp-for="NamaLengkap" class="form-label">Nama Lengkap</label>
                        <input asp-for="NamaLengkap" class="form-control" placeholder="Nama lengkap pendonor" />
                        <span asp-validation-for="NamaLengkap" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Umur" class="form-label">Umur</label>
                        <input asp-for="Umur" class="form-control" type="number" min="17" max="65" placeholder="17-65" />
                        <span asp-validation-for="Umur" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="JenisKelamin" class="form-label">Jenis Kelamin</label>
                        <select asp-for="JenisKelamin" class="form-select">
                            <option value="">-- Pilih --</option>
                            @foreach (var j in ViewBag.JenisKelaminList as List<string>)
                            {
                                <option value="@j">@j</option>
                            }
                        </select>
                        <span asp-validation-for="JenisKelamin" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="GolonganDarah" class="form-label">Golongan Darah</label>
                        <select asp-for="GolonganDarah" class="form-select">
                            <option value="">-- Pilih --</option>
                            @foreach (var g in ViewBag.GolonganDarahList as List<string>)
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                        <span asp-validation-for="GolonganDarah" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Rhesus" class="form-label">Rhesus</label>
                        <select asp-for="Rhesus" class="form-select">
                            <option value="">-- Pilih --</option>
                            @foreach (var r in ViewBag.RhesusList as List<string>)
                            {
                                <option value="@r">@(r == "+" ? "+ (Positif)" : "- (Negatif)")</option>
                            }
                        </select>
                        <span asp-validation-for="Rhesus" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Alamat" class="form-label">Alamat</label>
                    <textarea asp-for="Alamat" class="form-control" rows="2" placeholder="Alamat lengkap"></textarea>
                    <span asp-validation-for="Alamat" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NoHp" class="form-label">No. HP</label>
                        <input asp-for="NoHp" class="form-control" placeholder="08xxxxxxxxxx" />
                        <span asp-validation-for="NoHp" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label">Email <span style="color:#95a5a6;font-weight:400">(opsional)</span></label>
                        <input asp-for="Email" class="form-control" placeholder="email@gmail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TanggalLahir" class="form-label">Tanggal Lahir <span style="color:#95a5a6;font-weight:400">(opsional)</span></label>
                        <input asp-for="TanggalLahir" class="form-control" type="date" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DonorTerakhir" class="form-label">Donor Terakhir <span style="color:#95a5a6;font-weight:400">(opsional)</span></label>
                        <input asp-for="DonorTerakhir" class="form-control" type="date" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Keterangan" class="form-label">Keterangan <span style="color:#95a5a6;font-weight:400">(opsional)</span></label>
                    <textarea asp-for="Keterangan" class="form-control" rows="2"></textarea>
                </div>

                <div style="display:flex;gap:10px">
                    <button type="submit" class="bc-btn-primary">Simpan Pendonor</button>
                    <a asp-action="Index" class="bc-btn-secondary">Batal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
