@model IEnumerable<BloodCare.Models.Pendonor>

@{
    ViewData["Title"] = "Data Pendonor";
    var stokPerGol = ViewBag.StokPerGol as IEnumerable<dynamic>;
}

<!-- PAGE HERO -->
<div class="bc-page-hero mb-4">
    <div>
        <h3>Data Pendonor</h3>
        <p>Kelola data pendonor darah secara lebih cepat, rapi, dan terorganisir.</p>
    </div>
    <a asp-action="Create" class="bc-hero-btn">
        <i class="fa fa-plus-circle me-1"></i> Tambah Pendonor
    </a>
</div>

<!-- MINI STATS -->
<div class="bc-mini-stats mb-4">
    <div class="bc-mini-stat">
        <div class="bc-mini-stat-icon red"><i class="fa fa-users"></i></div>
        <div>
            <div style="font-size:0.75rem;color:#7f8c8d;text-transform:uppercase;letter-spacing:0.05em">Total Pendonor</div>
            <div class="bc-mini-stat-val">@ViewBag.TotalPendonor.ToString("N0")</div>
            <div class="bc-mini-stat-sub" style="color:#27ae60">↑ +12% dari bulan lalu</div>
        </div>
    </div>
    <div class="bc-mini-stat">
        <div class="bc-mini-stat-icon blue"><i class="fa fa-tint"></i></div>
        <div>
            <div style="font-size:0.75rem;color:#7f8c8d;text-transform:uppercase;letter-spacing:0.05em">Golongan Darah</div>
            <div style="display:flex;gap:6px;margin-top:6px;flex-wrap:wrap">
                @if (stokPerGol != null)
                {
                    foreach (var s in stokPerGol)
                    {
                        <span style="background:#c0392b;color:#fff;border-radius:20px;padding:3px 10px;font-size:0.78rem;font-weight:700">
                            @s.Gol: @s.Total
                        </span>
                    }
                }
            </div>
        </div>
    </div>
    <div class="bc-mini-stat">
        <div class="bc-mini-stat-icon green"><i class="fa fa-shield-alt"></i></div>
        <div>
            <div style="font-size:0.75rem;color:#7f8c8d;text-transform:uppercase;letter-spacing:0.05em">Status Sistem</div>
            <div style="font-weight:700;font-size:1rem;margin-top:4px">Aktif & Sinkron</div>
            <div class="bc-mini-stat-sub" style="color:#7f8c8d">Terakhir diperbarui: 5 menit lalu</div>
        </div>
    </div>
</div>

<!-- FILTER & SEARCH -->
<div class="bc-card mb-3">
    <div class="bc-card-header">
        <span class="bc-card-title">Daftar Pendonor</span>
        <div style="display:flex;gap:8px;align-items:center">
            <form asp-action="Index" method="get" style="display:flex;gap:8px">
                <input type="text" name="search" class="form-control form-control-sm"
                       placeholder="Cari nama / no HP..." value="@ViewBag.Search"
                       style="width:200px;border-radius:7px" />
                <select name="filterGol" class="form-select form-select-sm" style="width:120px;border-radius:7px">
                    <option value="">Semua Gol.</option>
                    @foreach (var g in new[]{"A","B","AB","O"})
                    {
                        <option value="@g" selected="@(ViewBag.FilterGol == g)">Gol. @g</option>
                    }
                </select>
                <button type="submit" class="bc-btn-primary" style="padding:6px 14px;font-size:0.82rem">
                    <i class="fa fa-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.FilterGol as string))
                {
                    <a asp-action="Index" class="bc-btn-secondary" style="padding:6px 14px;font-size:0.82rem">Reset</a>
                }
            </form>
            <button class="bc-icon-btn" title="Export"><i class="fa fa-download"></i></button>
        </div>
    </div>

    <table class="bc-table">
        <thead>
            <tr>
                <th>Nama</th>
                <th>Umur</th>
                <th>Jenis Kelamin</th>
                <th>Gol. Darah</th>
                <th>Rhesus</th>
                <th>Alamat</th>
                <th>No HP</th>
                <th>Donor Terakhir</th>
                <th>Status</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="10" style="text-align:center;padding:32px;color:#95a5a6">
                        Belum ada data pendonor
                    </td>
                </tr>
            }
            @foreach (var item in Model)
            {
                string[] parts = item.NamaLengkap.Split(' ');
                string inisial = parts[0].Substring(0,1).ToUpper();
                if (parts.Length > 1) inisial += parts[1].Substring(0,1).ToUpper();

                string statusClass = item.Status == "Aktif" ? "bc-badge-success" : "bc-badge-secondary";

                <tr>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px">
                            <span class="bc-tbl-avatar" style="background:#c0392b">@inisial</span>
                            <div>
                                <div class="bc-tbl-name">@item.NamaLengkap</div>
                                <div class="bc-tbl-sub">@(item.Email ?? "-")</div>
                            </div>
                        </div>
                    </td>
                    <td>@item.Umur</td>
                    <td>@item.JenisKelamin</td>
                    <td>
                        <span style="background:#c0392b;color:#fff;width:30px;height:30px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:0.8rem">
                            @item.GolonganDarah
                        </span>
                    </td>
                    <td style="font-weight:600;color:@(item.Rhesus == "+" ? "#27ae60" : "#c0392b")">
                        @(item.Rhesus == "+" ? "+ (Positif)" : "- (Negatif)")
                    </td>
                    <td style="font-size:0.82rem;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                        @item.Alamat
                    </td>
                    <td style="font-size:0.82rem">@item.NoHp</td>
                    <td style="font-size:0.82rem;color:#7f8c8d">
                        @(item.DonorTerakhir.HasValue ? item.DonorTerakhir.Value.ToString("dd MMM yyyy") : "-")
                    </td>
                    <td><span class="bc-badge @statusClass">@item.Status</span></td>
                    <td>
                        <div style="display:flex;gap:5px">
                            <a asp-action="Details" asp-route-id="@item.Id" class="bc-btn-detail">Detail</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="bc-btn-edit">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="bc-btn-del btn-confirm-delete"
                                        data-nama="@item.NamaLengkap">Hapus</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="bc-pagination">
        <span>Menampilkan @Model.Count() dari @ViewBag.TotalPendonor pendonor</span>
        <div class="bc-page-btn active">1</div>
    </div>
</div>
