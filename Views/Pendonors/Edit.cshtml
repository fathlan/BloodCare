@model BloodCare.Models.Pendonor

@{
    ViewData["Title"] = "Edit Pendonor";
}

<div style="max-width:700px;margin:0 auto">
    <div class="bc-form-card">
        <div class="bc-form-header" style="background:linear-gradient(135deg,#d35400,#e67e22)">
            <h5> Edit Data Pendonor</h5>
            <div style="font-size:0.82rem;opacity:0.85;margin-top:3px">Perbarui data pendonor darah</div>
        </div>
        <div class="bc-form-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="TanggalDaftar" />

                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label asp-for="NamaLengkap" class="form-label">Nama Lengkap</label>
                        <input asp-for="NamaLengkap" class="form-control" />
                        <span asp-validation-for="NamaLengkap" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Umur" class="form-label">Umur</label>
                        <input asp-for="Umur" class="form-control" type="number" min="17" max="65" />
                        <span asp-validation-for="Umur" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="JenisKelamin" class="form-label">Jenis Kelamin</label>
                        <select asp-for="JenisKelamin" class="form-select">
                            @foreach (var j in ViewBag.JenisKelaminList as List<string>)
                            {
                                <option value="@j">@j</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="GolonganDarah" class="form-label">Golongan Darah</label>
                        <select asp-for="GolonganDarah" class="form-select">
                            @foreach (var g in ViewBag.GolonganDarahList as List<string>)
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Rhesus" class="form-label">Rhesus</label>
                        <select asp-for="Rhesus" class="form-select">
                            @foreach (var r in ViewBag.RhesusList as List<string>)
                            {
                                <option value="@r">@(r == "+" ? "+ (Positif)" : "- (Negatif)")</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Alamat" class="form-label">Alamat</label>
                    <textarea asp-for="Alamat" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Alamat" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NoHp" class="form-label">No. HP</label>
                        <input asp-for="NoHp" class="form-control" />
                        <span asp-validation-for="NoHp" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="TanggalLahir" class="form-label">Tanggal Lahir</label>
                        <input asp-for="TanggalLahir" class="form-control" type="date" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="DonorTerakhir" class="form-label">Donor Terakhir</label>
                        <input asp-for="DonorTerakhir" class="form-control" type="date" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status" class="form-select">
                            @foreach (var s in ViewBag.StatusList as List<string>)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Keterangan" class="form-label">Keterangan</label>
                    <textarea asp-for="Keterangan" class="form-control" rows="2"></textarea>
                </div>

                <div style="display:flex;gap:10px">
                    <button type="submit" class="bc-btn-primary" style="background:#d35400">Update Data</button>
                    <a asp-action="Index" class="bc-btn-secondary">Batal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
