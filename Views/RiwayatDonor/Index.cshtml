@model IEnumerable<BloodCare.Models.RiwayatDonor>
@{
    ViewData["Title"] = "Input Riwayat Donor";
    bool bukaForm = !ViewData.ModelState.IsValid;
}

<div class="bc-hero mb-4" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
    <div>
        <h2 style="font-size:1.7rem;font-weight:800;margin-bottom:6px">Input Riwayat Donor</h2>
        <p style="opacity:0.88;font-size:0.92rem;max-width:600px">
            Catat hasil kegiatan donor darah di lapangan secara real-time untuk pembaruan inventaris otomatis.
        </p>
    </div>
    <button type="button" id="btnToggleForm" class="bc-hero-btn">
        <span id="btnToggleFormText">@(bukaForm ? "− Tutup Form" : "+ Input Riwayat Baru")</span>
    </button>
</div>

<div id="formWrapper" style="display:@(bukaForm ? "block" : "none")">
    <form asp-controller="RiwayatDonor" asp-action="Create" method="post" id="formRiwayat">
        @Html.AntiForgeryToken()

        <div class="bc-card mb-4" style="padding:26px">
            <div class="row g-3">

                <!-- NAMA PENDONOR: Select2, satu-satunya sumber = tabel Pendonors -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Nama Pendonor</label>
                    <select id="namaPendonorSelect" class="form-select" style="width:100%" required>
                        <option value=""></option>
                        @foreach (var p in (List<BloodCare.Models.Pendonor>)ViewBag.DaftarPendonor)
                        {
                            <option value="@p.Id" data-golongan="@p.GolonganDarah" data-rhesus="@p.Rhesus" data-nama="@p.NamaLengkap">
                                @p.NamaLengkap &mdash; @p.GolonganDarah@p.Rhesus (@p.NoHp)
                            </option>
                        }
                    </select>
                    <input type="hidden" id="pendonorIdHidden" name="PendonorId" />
                    <input type="hidden" id="namaPendonorHidden" name="NamaPendonor" />
                    <div class="form-text">
                        Nama belum ada di daftar? <a asp-controller="Pendonors" asp-action="Create" target="_blank">Tambah Pendonor baru</a> dulu.
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tanggal Donor</label>
                    <input type="date" name="TanggalDonor" class="form-control"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>

                <!-- LOKASI DONOR: pilih dari jadwal donor yang masih aktif -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Lokasi Donor</label>
                    <select id="lokasiDonorSelect" class="form-select" required>
                        <option value="">-- Pilih Jadwal Donor --</option>
                        @foreach (var j in (IEnumerable<dynamic>)ViewBag.DaftarJadwal)
                        {
                            <option value="@j.Lokasi" data-jadwalid="@j.Id">
                                @j.Lokasi &mdash; @(((DateTime)j.Tanggal).ToString("dd MMM yyyy"))
                            </option>
                        }
                        <option value="__manual__">Lokasi Lain (isi manual)</option>
                    </select>
                    <input type="text" id="lokasiDonorManualInput" class="form-control mt-2" style="display:none" placeholder="Tulis nama lokasi..." />
                    <input type="hidden" id="lokasiDonorHidden" name="LokasiDonor" />
                    <input type="hidden" id="jadwalDonorIdHidden" name="JadwalDonorId" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Jumlah Darah (ml)</label>
                    <input type="number" name="JumlahDarahMl" class="form-control" placeholder="Contoh: 350" min="50" max="1000" required />
                </div>

                <!-- GOLONGAN DARAH & RHESUS: selalu readonly, otomatis dari data Pendonor -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Golongan Darah</label>
                    <input type="text" id="golonganDarah" name="GolonganDarah" class="form-control bg-light" readonly placeholder="Pilih pendonor dulu" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Rhesus</label>
                    <input type="text" id="rhesus" name="Rhesus" class="form-control bg-light" readonly placeholder="Pilih pendonor dulu" />
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Catatan Tambahan</label>
                    <textarea name="CatatanTambahan" class="form-control" rows="3" placeholder="Masukkan observasi medis atau catatan khusus di sini..."></textarea>
                </div>
            </div>

            <div style="background:#fdecea;border-left:4px solid #c0392b;border-radius:8px;padding:14px 18px;margin-top:20px;font-size:0.85rem;color:#7b241c">
                <i class="fa fa-info-circle"></i>
                Data riwayat donor yang disimpan akan otomatis memperbarui stok darah di dashboard inventaris nasional secara real-time.
            </div>

            <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:20px">
                <button type="button" id="btnBatalForm" class="bc-btn-edit">Batal</button>
                <button type="submit" class="bc-hero-btn"><i class="fa fa-save"></i> Simpan</button>
            </div>
        </div>
    </form>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="bc-card">
            <div class="bc-card-header">
                <span class="bc-card-title" style="font-weight:700">Input Terkini</span>
                <a asp-action="Index" class="bc-card-link">Lihat Semua &rarr;</a>
            </div>
            <table class="bc-table">
                <thead>
                    <tr><th>Pendonor</th><th>Waktu</th><th>Gol</th><th>Volume</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var r in Model)
                        {
                            <tr>
                                <td class="bc-tbl-name">@r.NamaPendonor</td>
                                <td style="font-size:0.82rem">@r.WaktuInput.ToString("HH:mm") WIB</td>
                                <td>@r.GolonganDarah@r.Rhesus</td>
                                <td>@r.JumlahDarahMl ml</td>
                                <td><span class="bc-badge bc-badge-success">@r.Status</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" style="text-align:center;padding:24px;color:#95a5a6">Belum ada riwayat donor diinput</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="bc-card" style="padding:20px">
            <div class="bc-card-title" style="font-weight:700;margin-bottom:14px">Statistik Harian</div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
                <span style="font-size:0.82rem;color:#7f8c8d">Total Kantong</span>
                <strong style="font-size:1.3rem;color:#c0392b">@ViewBag.TotalKantongHariIni</strong>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center">
                <span style="font-size:0.82rem;color:#7f8c8d">Target Harian</span>
                <strong style="font-size:1.3rem">@ViewBag.TargetHarianPersen%</strong>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js"></script>
    <script>
        $(function () {

            // SEMBUNYIKAN FORM
            $('#btnToggleForm').on('click', function () {
                $('#formWrapper').slideToggle(200, function () {
                    var isVisible = $('#formWrapper').is(':visible');
                    $('#btnToggleFormText').text(isVisible ? '− Tutup Form' : '+ Input Riwayat Baru');

                    if (isVisible) {
                        $('html, body').animate({ scrollTop: $('#formWrapper').offset().top - 20 }, 300);
                    }
                });
            });

            $('#btnBatalForm').on('click', function () {
                $('#formWrapper').slideUp(200);
                $('#btnToggleFormText').text('+ Input Riwayat Baru');
                resetForm();
            });

            function resetForm() {
                $('#formRiwayat')[0].reset();
                $('#namaPendonorSelect').val(null).trigger('change');
                $('#pendonorIdHidden, #namaPendonorHidden, #golonganDarah, #rhesus, #lokasiDonorHidden, #jadwalDonorIdHidden').val('');
                $('#lokasiDonorSelect').val('');
                $('#lokasiDonorManualInput').hide().val('');
            }

            // SELECT2: pilih dari daftar Pendonors yang sudah di-preload
            // (sumbernya sama dengan fitur "Tambah Pendonor" -- tanpa ajax, tanpa ketik manual)
            $('#namaPendonorSelect').select2({
                placeholder: 'Ketik atau pilih nama pendonor...',
                width: '100%'
            });

            $('#namaPendonorSelect').on('select2:select', function (e) {
                var opt = $(this).find('option:selected');
                $('#pendonorIdHidden').val(opt.val());
                $('#namaPendonorHidden').val(opt.data('nama'));
                $('#golonganDarah').val(opt.data('golongan'));
                $('#rhesus').val(opt.data('rhesus'));
            });

            $('#namaPendonorSelect').on('select2:clear', function () {
                $('#pendonorIdHidden, #namaPendonorHidden, #golonganDarah, #rhesus').val('');
            });

            // LOKASI DONOR: pilih dari jadwal aktif, atau isi manual kalau tidak ada di daftar
            $('#lokasiDonorSelect').on('change', function () {
                var val = $(this).val();
                var jadwalId = $(this).find(':selected').data('jadwalid') || '';

                if (val === '__manual__') {
                    $('#lokasiDonorManualInput').show().val('');
                    $('#lokasiDonorHidden').val('');
                    $('#jadwalDonorIdHidden').val('');
                } else {
                    $('#lokasiDonorManualInput').hide().val('');
                    $('#lokasiDonorHidden').val(val);
                    $('#jadwalDonorIdHidden').val(jadwalId);
                }
            });

            $('#lokasiDonorManualInput').on('input', function () {
                $('#lokasiDonorHidden').val($(this).val());
            });

            //VALIDASI
            $('#formRiwayat').on('submit', function (e) {
                if (!$('#pendonorIdHidden').val()) {
                    e.preventDefault();
                    alert('Silakan pilih nama pendonor dari daftar terlebih dahulu.');
                    return;
                }
                if (!$('#lokasiDonorHidden').val().trim()) {
                    e.preventDefault();
                    alert('Silakan pilih atau isi lokasi donor.');
                    return;
                }
            });
        });
    </script>
}
