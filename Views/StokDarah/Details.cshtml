@model BloodCare.Models.StokDarah

@{
    ViewData["Title"] = "Detail Stok Darah";
}

<section class="blood-hero">
    <div>
        <span class="badge-soft">BloodCare Stock</span>
        <h1>Detail Stok Darah</h1>
        <p>Informasi lengkap stok darah yang tersimpan di sistem.</p>
    </div>

    <a asp-action="Index" class="btn-hero">Kembali</a>
</section>

<section class="detail-card">
    <div class="detail-item">
        <span>Golongan Darah</span>
        <strong>@Model.GolonganDarah</strong>
    </div>

    <div class="detail-item">
        <span>Rhesus</span>
        <strong>@Model.Rhesus</strong>
    </div>

    <div class="detail-item">
        <span>Jumlah Kantong</span>
        <strong>@Model.JumlahKantong Kantong</strong>
    </div>

    <div class="detail-item">
        <span>Tanggal Masuk</span>
        <strong>@Model.TanggalMasuk.ToString("dd/MM/yyyy")</strong>
    </div>

    <div class="detail-item">
        <span>Tanggal Kadaluarsa</span>
        <strong>@Model.TanggalKadaluarsa.ToString("dd/MM/yyyy")</strong>
    </div>

    <div class="form-actions">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-save">Edit Data</a>
        <a asp-action="Index" class="btn-cancel">Kembali</a>
    </div>
</section>