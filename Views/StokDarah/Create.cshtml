@model BloodCare.Models.StokDarah

@{
    ViewData["Title"] = "Tambah Stok Darah";
}

<div style="max-width:560px;margin:0 auto">
    <div class="bc-form-card">
        <div class="bc-form-header">
            <h5> Tambah Stok Darah</h5>
            <div style="font-size:0.82rem;opacity:0.85;margin-top:3px">Input data stok darah baru</div>
        </div>
        <div class="bc-form-body">
            <form asp-action="Create">
                <div class="row">
                    <div class="col-6 mb-3">
                        <label asp-for="GolonganDarah" class="form-label">Golongan Darah</label>
                        <select asp-for="GolonganDarah" class="form-select">
                            <option value="">-- Pilih --</option>
                            @foreach (var g in ViewBag.GolonganDarahList as List<string>)
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                        <span asp-validation-for="GolonganDarah" class="text-danger small"></span>
                    </div>
                    <div class="col-6 mb-3">
                        <label asp-for="Rhesus" class="form-label">Rhesus</label>
                        <select asp-for="Rhesus" class="form-select">
                            <option value="">-- Pilih --</option>
                            @foreach (var r in ViewBag.RhesusList as List<string>)
                            {
                                <option value="@r">@(r == "+" ? "+ (Positif)" : "- (Negatif)")</option>
                            }
                        </select>
                        <span asp-validation-for="Rhesus" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="JumlahKantong" class="form-label">Jumlah Kantong</label>
                    <input asp-for="JumlahKantong" class="form-control" type="number" min="0" placeholder="Jumlah kantong darah" />
                    <span asp-validation-for="JumlahKantong" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="TanggalKadaluarsa" class="form-label">Tanggal Kadaluarsa <span style="color:#95a5a6;font-weight:400">(opsional)</span></label>
                    <input asp-for="TanggalKadaluarsa" class="form-control" type="date" />
                </div>
                <div class="mb-4">
                    <label asp-for="Keterangan" class="form-label">Keterangan <span style="color:#95a5a6;font-weight:400">(opsional)</span></label>
                    <textarea asp-for="Keterangan" class="form-control" rows="2"></textarea>
                </div>
                <div style="display:flex;gap:10px">
                    <button type="submit" class="bc-btn-primary">Simpan Stok</button>
                    <a asp-action="Index" class="bc-btn-secondary">Batal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
