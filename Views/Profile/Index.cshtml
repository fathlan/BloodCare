@{
    ViewData["Title"] = "Profil";
    string fullName = ViewBag.FullName ?? "User";
    string initials = string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(w => char.ToUpper(w[0])));
}

<div class="bc-hero mb-4">
    <div>
        <h2 style="font-size:1.7rem;font-weight:800;margin-bottom:6px">Profil Saya</h2>
        <p style="opacity:0.88;font-size:0.92rem">Informasi akun Anda di BloodCare System.</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="bc-card" style="padding:28px;text-align:center">
            <div style="width:84px;height:84px;border-radius:50%;background:#c0392b;color:#fff;
                        display:flex;align-items:center;justify-content:center;font-size:1.6rem;
                        font-weight:800;margin:0 auto 16px">
                @initials
            </div>
            <div style="font-weight:800;font-size:1.1rem">@fullName</div>
            <span class="bc-badge bc-badge-success" style="margin-top:8px;display:inline-block">@ViewBag.RoleLabel</span>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="bc-card">
            <div class="bc-card-header">
                <span class="bc-card-title" style="font-weight:700">Detail Akun</span>
            </div>
            <div style="padding:22px">
                <div class="mb-3">
                    <div style="font-size:0.78rem;color:#95a5a6;text-transform:uppercase">Nama Lengkap</div>
                    <div style="font-weight:600">@fullName</div>
                </div>
                <div class="mb-3">
                    <div style="font-size:0.78rem;color:#95a5a6;text-transform:uppercase">Email</div>
                    <div style="font-weight:600">@ViewBag.Email</div>
                </div>
                <div class="mb-3">
                    <div style="font-size:0.78rem;color:#95a5a6;text-transform:uppercase">No. Telepon</div>
                    <div style="font-weight:600">@(ViewBag.PhoneNumber ?? "-")</div>
                </div>
                <div>
                    <div style="font-size:0.78rem;color:#95a5a6;text-transform:uppercase">Peran</div>
                    <div style="font-weight:600">@ViewBag.RoleLabel</div>
                </div>
            </div>
        </div>
    </div>
</div>
