@model BloodCare.Models.JadwalDonor

@{
    ViewData["Title"] = "Edit Jadwal Donor";
}

<div style="max-width:640px;margin:0 auto">
    <div class="bc-form-card">
        <div class="bc-form-header" style="background:linear-gradient(135deg,#d35400,#e67e22)">
            <h5>Edit Jadwal Donor</h5>
            <div style="font-size:0.82rem;opacity:0.85;margin-top:3px">Perbarui data jadwal kegiatan donor darah</div>
        </div>
        <div class="bc-form-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Lokasi" class="form-label">Lokasi</label>
                    <input asp-for="Lokasi" class="form-control" />
                    <span asp-validation-for="Lokasi" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Tanggal" class="form-label">Tanggal</label>
                    <input asp-for="Tanggal" class="form-control" type="date" />
                    <span asp-validation-for="Tanggal" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Kuota" class="form-label">Kuota Peserta</label>
                    <input asp-for="Kuota" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Kuota" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Keterangan" class="form-label">Keterangan <span style="color:#95a5a6;font-weight:400">(opsional)</span></label>
                    <textarea asp-for="Keterangan" class="form-control" rows="3"></textarea>
                </div>
                <div style="display:flex;gap:10px">
                    <button type="submit" class="bc-btn-primary" style="background:#d35400">Update Jadwal</button>
                    <a asp-action="Index" class="bc-btn-secondary">Batal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
