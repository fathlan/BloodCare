@model BloodCare.Models.AuditLog

@{
    ViewData["Title"] = "Detail Log";
    string actionClass = Model.Action switch
    {
        "Login"          => "bc-badge-success",
        "Logout"         => "bc-badge-secondary",
        "Register"       => "bc-badge-info",
        "Create"         => "bc-badge-info",
        "Update" or "UpdateUser"  => "bc-badge-warning",
        "Delete" or "DeleteUser"  => "bc-badge-danger",
        "ResetPassword"  => "bc-badge-process",
        _                => "bc-badge-secondary"
    };
}

<div style="max-width:700px;margin:0 auto">
    <div class="bc-form-card">
        <div class="bc-form-header">
            <h5>📋 Detail Log Aktivitas</h5>
            <div style="font-size:0.82rem;opacity:0.85;margin-top:3px">
                ID Log: #@Model.Id
            </div>
        </div>
        <div class="bc-form-body">

            <!-- Info Utama -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px">
                <div style="background:#fafbfc;border-radius:10px;padding:14px">
                    <div style="font-size:0.75rem;color:#95a5a6;margin-bottom:4px">WAKTU</div>
                    <div style="font-weight:700">@Model.Timestamp.ToString("dd MMMM yyyy")</div>
                    <div style="color:#7f8c8d;font-size:0.85rem">@Model.Timestamp.ToString("HH:mm:ss")</div>
                </div>
                <div style="background:#fafbfc;border-radius:10px;padding:14px">
                    <div style="font-size:0.75rem;color:#95a5a6;margin-bottom:4px">AKSI</div>
                    <span class="bc-badge @actionClass" style="font-size:0.85rem">@Model.Action</span>
                </div>
                <div style="background:#fafbfc;border-radius:10px;padding:14px">
                    <div style="font-size:0.75rem;color:#95a5a6;margin-bottom:4px">USER</div>
                    <div style="font-weight:700;font-size:0.88rem">@(Model.UserName ?? "-")</div>
                    <div style="color:#95a5a6;font-size:0.75rem;font-family:monospace">@(Model.UserId ?? "-")</div>
                </div>
                <div style="background:#fafbfc;border-radius:10px;padding:14px">
                    <div style="font-size:0.75rem;color:#95a5a6;margin-bottom:4px">TABEL</div>
                    <div style="font-weight:700">@Model.TableName</div>
                    <div style="color:#95a5a6;font-size:0.75rem">Record: @(Model.RecordId ?? "-")</div>
                </div>
            </div>

            <!-- Old Values -->
            @if (!string.IsNullOrEmpty(Model.OldValues))
            {
                <div class="mb-3">
                    <div style="font-size:0.82rem;font-weight:600;color:#c0392b;margin-bottom:6px">
                        📤 Data Sebelum (Old Values)
                    </div>
                    <div style="background:#fdecea;border:1px solid #f5b7b1;border-radius:8px;padding:12px;font-family:monospace;font-size:0.82rem;color:#922b21;white-space:pre-wrap">@Model.OldValues</div>
                </div>
            }

            <!-- New Values -->
            @if (!string.IsNullOrEmpty(Model.NewValues))
            {
                <div class="mb-3">
                    <div style="font-size:0.82rem;font-weight:600;color:#1e8449;margin-bottom:6px">
                        📥 Data Sesudah (New Values)
                    </div>
                    <div style="background:#e8f8f0;border:1px solid #a9dfbf;border-radius:8px;padding:12px;font-family:monospace;font-size:0.82rem;color:#1a5276;white-space:pre-wrap">@Model.NewValues</div>
                </div>
            }

            @if (string.IsNullOrEmpty(Model.OldValues) && string.IsNullOrEmpty(Model.NewValues))
            {
                <div style="text-align:center;color:#95a5a6;padding:20px;background:#fafbfc;border-radius:8px">
                    Tidak ada detail perubahan data untuk log ini
                </div>
            }

            <div style="margin-top:20px">
                <a asp-action="Index" class="bc-btn-secondary">← Kembali ke Daftar Log</a>
            </div>
        </div>
    </div>
</div>
