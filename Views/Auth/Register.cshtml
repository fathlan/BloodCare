@model BloodCare.ViewModels.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Daftar - BloodCare</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #b71c1c 0%, #7f0000 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
        }
        .login-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            padding: 40px;
            width: 100%;
            max-width: 640px;
        }
        .login-logo { text-align: center; margin-bottom: 24px; }
        .login-logo h2 { color: #b71c1c; font-weight: 700; margin: 0; }
        .login-logo p { color: #777; font-size: 14px; }
        .btn-bloodcare {
            background: #b71c1c; border: none; width: 100%;
            padding: 10px; font-weight: 600; color: #fff;
        }
        .btn-bloodcare:hover { background: #7f0000; color: #fff; }
        .login-footer { text-align: center; margin-top: 16px; font-size: 14px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <h2>BloodCare</h2>
            <p>Daftar sebagai Pendonor</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Auth" asp-action="Register" method="post">
            <div class="mb-3">
                <label asp-for="FullName" class="form-label">Nama Lengkap</label>
                <input asp-for="FullName" class="form-control" placeholder="Nama kamu" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="nama@email.com" autocomplete="username" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Minimal 6 karakter" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Konfirmasi Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Ulangi password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <hr class="my-3" />
            <p class="text-muted small mb-2">Data pendukung sebagai pendonor</p>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Umur" class="form-label">Umur</label>
                    <input asp-for="Umur" type="number" class="form-control" placeholder="17 - 65" />
                    <span asp-validation-for="Umur" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="JenisKelamin" class="form-label">Jenis Kelamin</label>
                    <select asp-for="JenisKelamin" class="form-select">
                        <option value="">-- Pilih --</option>
                        <option value="Laki-laki">Laki-laki</option>
                        <option value="Perempuan">Perempuan</option>
                    </select>
                    <span asp-validation-for="JenisKelamin" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="GolonganDarah" class="form-label">Golongan Darah</label>
                    <select asp-for="GolonganDarah" class="form-select">
                        <option value="">-- Pilih --</option>
                        <option value="A">A</option><option value="B">B</option>
                        <option value="AB">AB</option><option value="O">O</option>
                    </select>
                    <span asp-validation-for="GolonganDarah" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Rhesus" class="form-label">Rhesus</label>
                    <select asp-for="Rhesus" class="form-select">
                        <option value="">-- Pilih --</option>
                        <option value="+">Positif (+)</option>
                        <option value="-">Negatif (-)</option>
                    </select>
                    <span asp-validation-for="Rhesus" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="NoHp" class="form-label">No. HP</label>
                    <input asp-for="NoHp" class="form-control" placeholder="08xxxxxxxxxx" />
                    <span asp-validation-for="NoHp" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="TanggalLahir" class="form-label">Tanggal Lahir</label>
                    <input asp-for="TanggalLahir" type="date" class="form-control" />
                    <span asp-validation-for="TanggalLahir" class="text-danger small"></span>
                </div>
                <div class="col-12 mb-3">
                    <label asp-for="Alamat" class="form-label">Alamat</label>
                    <textarea asp-for="Alamat" class="form-control" rows="2" placeholder="Alamat lengkap"></textarea>
                    <span asp-validation-for="Alamat" class="text-danger small"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-bloodcare">Daftar</button>
        </form>

        <div class="login-footer">
            Sudah punya akun? <a href="/Auth/Login">Login di sini</a>
        </div>
    </div>
</body>
</html>
