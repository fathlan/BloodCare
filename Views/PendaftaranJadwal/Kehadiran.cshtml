@model IEnumerable<BloodCare.Models.PendaftaranJadwal>
@{
    ViewData["Title"] = "Verifikasi Kehadiran";
    var daftarJadwal = ViewBag.DaftarJadwal as IEnumerable<BloodCare.Models.JadwalDonor>;
    var jadwalInfo = ViewBag.JadwalInfo as BloodCare.Models.JadwalDonor;
    var sudahInputIds = ViewBag.SudahInputIds as List<int> ?? new List<int>();
}

<div class="bc-hero mb-4">
    <div>
        <h2 style="font-size:1.7rem;font-weight:800;margin-bottom:6px">Verifikasi Kehadiran</h2>
        <p style="opacity:0.88;font-size:0.92rem">
            Cek siapa yang benar-benar hadir sebelum menginput riwayat donor (UC012).
        </p>
    </div>
</div>

<div class="bc-card mb-3" style="padding:18px 22px">
    <form method="get" asp-action="Kehadiran" style="display:flex;gap:12px;align-items:center">
        <label class="fw-semibold">Pilih Jadwal:</label>
        <select name="jadwalId" class="form-select" style="max-width:420px" onchange="this.form.submit()">
            @if (daftarJadwal != null)
            {
                foreach (var j in daftarJadwal)
                {
                    <option value="@j.Id" selected="@(j.Id == (int?)ViewBag.JadwalDipilih)">
                        @j.Lokasi &mdash; @j.Tanggal.ToString("dd MMM yyyy")
                    </option>
                }
            }
        </select>
    </form>
</div>

@if (jadwalInfo != null)
{
    <div class="bc-card">
        <div class="bc-card-header">
            <span class="bc-card-title" style="font-weight:700">@jadwalInfo.Lokasi &mdash; @jadwalInfo.Tanggal.ToString("dd MMM yyyy")</span>
            <span style="font-size:0.82rem;color:#7f8c8d">Kuota: @jadwalInfo.Kuota orang</span>
        </div>
        <table class="bc-table">
            <thead><tr><th>Nama Pendonor</th><th>Tanggal Daftar</th><th>Status</th><th>Aksi</th></tr></thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var p in Model)
                    {
                        string badge = p.StatusKehadiran switch
                        {
                            "Hadir" => "bc-badge-success",
                            "Tidak Hadir" => "bc-badge-danger",
                            _ => "bc-badge-warning"
                        };

                        bool sudahInput = sudahInputIds.Contains(p.Id);

                        <tr>
                            <td class="bc-tbl-name">@p.NamaPendonor</td>
                            <td style="font-size:0.82rem">@p.TanggalDaftar.ToString("dd MMM yyyy HH:mm")</td>
                            <td><span class="bc-badge @badge">@p.StatusKehadiran</span></td>
                            <td style="display:flex;gap:6px;flex-wrap:wrap;align-items:center">
                                @if (sudahInput)
                                {
                                    <span class="bc-badge bc-badge-success" style="padding:5px 10px;font-size:0.78rem">
                                        <i class="fa fa-check-circle"></i> Riwayat Sudah Diinput
                                    </span>
                                }
                                else
                                {
                                    <form method="post" asp-action="SetKehadiran">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <input type="hidden" name="status" value="Hadir" />
                                        <button type="submit" class="bc-btn-edit" style="padding:5px 10px;font-size:0.78rem">
                                            <i class="fa fa-check"></i> Hadir
                                        </button>
                                    </form>
                                    <form method="post" asp-action="SetKehadiran">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <input type="hidden" name="status" value="Tidak Hadir" />
                                        <button type="submit" class="bc-btn-edit" style="padding:5px 10px;font-size:0.78rem">
                                            <i class="fa fa-times"></i> Tidak Hadir
                                        </button>
                                    </form>
                                    @if (p.StatusKehadiran == "Hadir")
                                    {
                                        <a asp-controller="RiwayatDonor" asp-action="Create" asp-route-pendaftaranId="@p.Id"
                                           class="bc-hero-btn" style="padding:5px 10px;font-size:0.78rem;text-decoration:none">
                                            <i class="fa fa-tint"></i> Input Riwayat Donor
                                        </a>
                                    }
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" style="text-align:center;padding:28px;color:#95a5a6">Belum ada pendonor yang mendaftar di jadwal ini.</td></tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="bc-card" style="text-align:center;padding:40px;color:#95a5a6">Belum ada jadwal donor tersedia.</div>
}
