@model List<BloodCare.Controllers.NotifItem>

<div style="max-height:420px;overflow-y:auto">
    @if (!Model.Any())
    {
        <div style="text-align:center;padding:28px 16px;color:#95a5a6;font-size:0.85rem">
            Tidak ada notifikasi saat ini
        </div>
    }
    @foreach (var notif in Model)
    {
        string borderColor = notif.IsUrgent ? "#c0392b" :
                             notif.Tipe == "jadwal" ? "#2471a3" :
                             notif.Tipe == "permintaan" ? "#27ae60" : "#95a5a6";
        TimeSpan selisih = DateTime.Now - notif.Waktu;
        string waktuLabel = selisih.TotalMinutes < 60
            ? $"{Math.Max(0, (int)selisih.TotalMinutes)} menit lalu"
            : selisih.TotalHours < 24
                ? $"{(int)selisih.TotalHours} jam lalu"
                : $"{notif.Waktu:dd MMM}";

        <div class="bc-notif-dropdown-item" data-id="@notif.Id"
             style="display:flex;gap:10px;padding:12px 16px;border-bottom:1px solid #f0f0f0;
                    background:@(notif.IsRead ? "#fff" : "#fff8f7");cursor:pointer">
            <div style="width:8px;height:8px;border-radius:50%;margin-top:6px;flex-shrink:0;
                        background:@(notif.IsRead ? "transparent" : borderColor)"></div>
            <div style="flex:1;min-width:0">
                <div style="font-weight:700;font-size:0.82rem;color:#1a1a2e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                    @notif.Judul
                </div>
                <div style="font-size:0.78rem;color:#7f8c8d;margin-top:2px;line-height:1.4;
                            display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                    @notif.Pesan
                </div>
                <div style="font-size:0.72rem;color:#b0b3ba;margin-top:4px">@waktuLabel</div>
            </div>
        </div>
    }
</div>
<div style="padding:10px 16px;text-align:center;border-top:1px solid #f0f0f0">
    <a asp-controller="Notifikasi" asp-action="Index" style="font-size:0.82rem;font-weight:600;color:#c0392b;text-decoration:none">
        Lihat Semua Notifikasi &rarr;
    </a>
</div>
