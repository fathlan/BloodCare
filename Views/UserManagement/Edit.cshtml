@model BloodCare.ViewModels.EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div style="max-width:640px;margin:0 auto">
    <div class="bc-form-card">
        <div class="bc-form-header" style="background:linear-gradient(135deg,#d35400,#e67e22)">
            <h5>✏️ Edit User</h5>
            <div style="font-size:0.82rem;opacity:0.85;margin-top:3px">Ubah role dan status akun pengguna</div>
        </div>
        <div class="bc-form-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Nama Lengkap</label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" readonly
                           style="background:#f5f6fa;cursor:not-allowed" />
                    <small style="color:#95a5a6">Email tidak bisa diubah</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label">Role</label>
                    <select asp-for="Role" class="form-select">
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Status Akun</label>
                    <div style="display:flex;gap:16px;margin-top:6px">
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                            <input type="radio" asp-for="IsActive" value="true"
                                   @@(Model.IsActive ? "checked" : "") />
                            <span class="bc-badge bc-badge-success">Aktif</span>
                        </label>
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                            <input type="radio" asp-for="IsActive" value="false"
                                   @@(!Model.IsActive ? "checked" : "") />
                            <span class="bc-badge bc-badge-secondary">Nonaktif</span>
                        </label>
                    </div>
                </div>

                <div style="display:flex;gap:10px">
                    <button type="submit" class="bc-btn-primary" style="background:#d35400">💾 Simpan Perubahan</button>
                    <a asp-action="Index" class="bc-btn-secondary">Batal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
