@model BloodCare.ViewModels.UserDetailViewModel

@{
    ViewData["Title"] = "Detail User";
}

<div style="max-width:640px;margin:0 auto">
    <div class="bc-form-card">
        <div class="bc-form-header">
            <h5>👤 Detail User</h5>
            <div style="font-size:0.82rem;opacity:0.85;margin-top:3px">Informasi lengkap akun pengguna</div>
        </div>
        <div class="bc-form-body">

            <!-- Avatar & Nama -->
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;padding:16px;background:#fafbfc;border-radius:10px">
                <div style="width:60px;height:60px;border-radius:50%;background:#c0392b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700">
                    @(Model.FullName.Length >= 1 ? Model.FullName.Substring(0,1).ToUpper() : "?")
                </div>
                <div>
                    <div style="font-weight:700;font-size:1.1rem">@Model.FullName</div>
                    <div style="color:#7f8c8d;font-size:0.85rem">@Model.Email</div>
                    @{
                        string roleClass = Model.Role == "Admin" ? "bc-badge-danger" :
                                           Model.Role == "Petugas" ? "bc-badge-warning" :
                                           Model.Role == "Pendonor" ? "bc-badge-success" : "bc-badge-secondary";
                    }
                    <span class="bc-badge @roleClass" style="margin-top:6px;display:inline-block">@Model.Role</span>
                </div>
            </div>

            <dl class="row" style="font-size:0.88rem">
                <dt class="col-sm-4" style="color:#7f8c8d">Status</dt>
                <dd class="col-sm-8">
                    @if (Model.IsActive)
                    {
                        <span class="bc-badge bc-badge-success">Aktif</span>
                    }
                    else
                    {
                        <span class="bc-badge bc-badge-secondary">Nonaktif</span>
                    }
                </dd>

                <dt class="col-sm-4" style="color:#7f8c8d">No. Telepon</dt>
                <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</dd>

                <dt class="col-sm-4" style="color:#7f8c8d">Role</dt>
                <dd class="col-sm-8">@Model.Role</dd>
            </dl>

            <div style="display:flex;gap:10px;margin-top:20px">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="bc-btn-primary">Edit User</a>
                <a asp-action="Index" class="bc-btn-secondary">Kembali</a>
            </div>
        </div>
    </div>
</div>
